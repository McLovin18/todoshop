rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    
    match /admin/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
      
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para emprendedores
    match /emprendedores/{emprendedorId} {
      // Lectura pública para que la página de reservas pueda obtener el teléfono
      allow read: if true;
      // Permitir consultas por uid o email para el propio usuario
      allow list: if isAdmin() || (
        isSignedIn() && (
          request.query.uid == request.auth.uid ||
          request.query.email == request.auth.token.email
        )
      );
      // Solo admin puede crear/editar/eliminar emprendedores
      // Emprendedor puede actualizar su propio documento (para teléfono)
      allow delete: if isAdmin();
      allow create, update: if isAdmin() || (
        isSignedIn() && (
          request.auth.uid == emprendedorId ||
          resource.data.email == request.auth.token.email
        )
      );
    }

    match /productos/{productId} {
      allow read: if true;
      // Solo admin puede escribir
      allow write: if isAdmin();
    }

    // Atributos / variaciones dinámicas
    match /atributos/{atributoId} {
      // Lectura pública para poblar selects en cliente admin
      allow read: if true;
      // Solo admin puede crear/editar/eliminar atributos
      allow create, update, delete: if isAdmin();
    }

    match /marcas/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categorias/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categoriasAlimentos/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /alimentos/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /reservas/{document=**} {
      // Lectura: el emprendedor puede leer sus propias reservas
      allow read: if isSignedIn() && (
        resource.data.emprendedorId == request.auth.uid ||
        isAdmin()
      );
      // Escritura: el emprendedor puede crear reservas para sus alimentos
      allow create: if isSignedIn();
      // Actualizar y eliminar: solo el emprendedor dueño o admin
      allow update, delete: if isSignedIn() && (
        resource.data.emprendedorId == request.auth.uid ||
        isAdmin()
      );
    }

    match /bodegas/{bodegaId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /landingPage/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /blogs/{blogId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow create, update, delete: if isAdmin();
    }
    
    match /ordenes/{orderId} {
      // Invitados y autenticados pueden crear órdenes
      allow create: if true;
      // El dueño puede leer su orden, el admin puede leer todas
      // Las órdenes de invitados (userId == null) solo las lee el admin
      allow read: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid
      );
      // Solo admin puede actualizar (aprobar, rechazar)
      allow update, delete: if isAdmin();
    }
    
    match /product_reviews/{reviewId} {
      // Cualquiera autenticado puede crear una reseña
      allow create: if true;
      // Solo el admin puede aprobar, rechazar o eliminar
      allow update, delete: if isAdmin();
      // Leer solo reseñas aprobadas, o si es admin
      allow read: if resource.data.approved == true || isAdmin();
    }

    // Contador secuencial: invitados también necesitan acceso para generar orderId
    match /ordenes_meta/{docId} {
      allow read, write: if true;
    }

    // Analytics: Todos pueden crear y actualizar (page views, clicks)
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if true;
    }
  }
}
